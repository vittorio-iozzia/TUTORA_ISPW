<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.ispw.tutora.controller.graphic.AdminContentController"
      spacing="28">

    <!-- ============================================================ -->
    <!-- Welcome                                                      -->
    <!-- ============================================================ -->
    <VBox spacing="4" styleClass="welcome-section">
        <Label fx:id="welcomeTitle" text="Admin Dashboard" styleClass="welcome-title"/>
        <Label text="Manage users, tutors, and platform settings" styleClass="welcome-subtitle"/>
    </VBox>

    <!-- ============================================================ -->
    <!-- Stats row                                                    -->
    <!-- ============================================================ -->
    <HBox spacing="20" styleClass="stats-row">

        <HBox fx:id="statCard1" styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
              spacing="18" alignment="CENTER_LEFT">
            <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>
            <StackPane styleClass="stat-icon-wrap,stat-blue">
                <FontIcon iconLiteral="fas-users" iconSize="18" styleClass="stat-icon"/>
            </StackPane>
            <VBox spacing="4">
                <Label fx:id="totalUsersLabel" text="0" styleClass="stat-value"/>
                <Label text="Total Users" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <HBox fx:id="statCard2" styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
              spacing="18" alignment="CENTER_LEFT">
            <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>
            <StackPane styleClass="stat-icon-wrap,stat-green">
                <FontIcon iconLiteral="fas-user-graduate" iconSize="18" styleClass="stat-icon"/>
            </StackPane>
            <VBox spacing="4">
                <Label fx:id="activeTutorsLabel" text="0" styleClass="stat-value"/>
                <Label text="Active Tutors" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <HBox fx:id="statCard3" styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
              spacing="18" alignment="CENTER_LEFT">
            <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>
            <StackPane styleClass="stat-icon-wrap,stat-purple">
                <FontIcon iconLiteral="fas-book-open" iconSize="18" styleClass="stat-icon"/>
            </StackPane>
            <VBox spacing="4">
                <Label fx:id="totalLessonsLabel" text="0" styleClass="stat-value"/>
                <Label text="Total Lessons" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <HBox fx:id="statCard4" styleClass="stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
              spacing="18" alignment="CENTER_LEFT">
            <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>
            <StackPane styleClass="stat-icon-wrap,stat-orange">
                <FontIcon iconLiteral="fas-euro-sign" iconSize="18" styleClass="stat-icon"/>
            </StackPane>
            <VBox spacing="4">
                <Label fx:id="revenueLabel" text="€0" styleClass="stat-value"/>
                <Label text="Platform Revenue" styleClass="stat-label"/>
            </VBox>
        </HBox>

    </HBox>

    <!-- ============================================================ -->
    <!-- TabPane                                                      -->
    <!-- ============================================================ -->
    <VBox styleClass="tab-panel-card" VBox.vgrow="ALWAYS">
        <TabPane styleClass="tutor-tabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">

            <!-- Tutor Approvals -->
            <Tab text="Tutor Approvals">
                <VBox spacing="12" styleClass="tab-content">
                    <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Label text="Pending Tutor Applications" styleClass="section-card-title"/>
                        <Label fx:id="pendingCountLabel" text="" styleClass="badge-pending"/>
                    </HBox>
                    <Label text="Review and approve new tutor registrations"
                           styleClass="tutor-tab-desc"/>
                    <VBox fx:id="applicationsList" spacing="10"/>
                </VBox>
            </Tab>

            <!-- User Management -->
            <Tab text="User Management">
                <VBox spacing="12" styleClass="tab-content">
                    <padding><Insets top="20" right="24" bottom="24" left="24"/></padding>
                    <HBox styleClass="search-box" alignment="CENTER_LEFT" spacing="12">
                        <FontIcon iconLiteral="fas-search" iconSize="16" styleClass="search-icon"/>
                        <TextField fx:id="userSearchField"
                                   promptText="Search tutors by name..."
                                   styleClass="search-input"
                                   HBox.hgrow="ALWAYS"/>
                    </HBox>
                    <VBox fx:id="usersList" spacing="8"/>
                </VBox>
            </Tab>

            <!-- Analytics -->
            <Tab text="Analytics">
                <VBox spacing="20" styleClass="tab-content" alignment="CENTER">
                    <padding><Insets top="60"/></padding>
                    <FontIcon iconLiteral="fas-chart-bar" iconSize="52"
                              styleClass="analytics-placeholder-icon"/>
                    <Label text="Analytics" styleClass="section-card-title"/>
                    <Label text="Chart visualizations coming soon."
                           styleClass="tutor-tab-desc" wrapText="true"/>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>

</VBox>
