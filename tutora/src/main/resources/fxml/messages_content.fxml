<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.GaussianBlur?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.ispw.tutora.controller.graphic.ChatGfxController"
      stylesheets="@../css/home.css"
      styleClass="chat-root"
      spacing="10"
      maxHeight="Infinity">
    <padding><Insets top="10" right="10" bottom="10" left="10"/></padding>

    <!-- ── Left sidebar: contact list (floating card) ── -->
    <VBox fx:id="chatSidebar" styleClass="chat-sidebar" spacing="0" minWidth="262" prefWidth="262" maxWidth="262">

        <HBox styleClass="chat-sidebar-header" alignment="CENTER_LEFT">
            <padding><Insets top="18" right="16" bottom="18" left="20"/></padding>
            <Label text="Conversations" styleClass="chat-sidebar-title"/>
        </HBox>

        <Separator styleClass="chat-sidebar-sep"/>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="chat-contact-scroll">
            <VBox fx:id="contactList" spacing="0"/>
        </ScrollPane>

    </VBox>

    <!-- ── Right: chat area (floating card) ── -->
    <VBox fx:id="chatMain" HBox.hgrow="ALWAYS" spacing="0" styleClass="chat-main-panel">

        <!-- Chat header — shown when a conversation is selected -->
        <HBox fx:id="chatHeader" styleClass="chat-header" alignment="CENTER_LEFT"
              spacing="12" managed="false" visible="false">
            <padding><Insets top="14" right="16" bottom="14" left="20"/></padding>
            <StackPane fx:id="chatHeaderAvatar" styleClass="chat-contact-avatar" minWidth="44" minHeight="44" maxWidth="44" maxHeight="44">
                <Label fx:id="chatHeaderInitial" styleClass="chat-contact-initial"/>
                <javafx.scene.image.ImageView fx:id="chatHeaderImageView" fitWidth="44" fitHeight="44" preserveRatio="false" smooth="true" visible="false"/>
            </StackPane>
            <VBox spacing="3">
                <Label fx:id="chatHeaderName" styleClass="chat-header-name"/>
                <Label fx:id="chatHeaderRole" styleClass="chat-header-role"/>
            </VBox>
            <!-- Spacer -->
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Action buttons -->
            <Button fx:id="callBtn" styleClass="chat-action-btn" onAction="#handleCall">
                <graphic><FontIcon iconLiteral="fas-phone" iconSize="15" styleClass="chat-action-icon"/></graphic>
            </Button>
            <Button fx:id="videoCallBtn" styleClass="chat-action-btn" onAction="#handleVideo">
                <graphic><FontIcon iconLiteral="fas-video" iconSize="15" styleClass="chat-action-icon"/></graphic>
            </Button>
            <Button fx:id="moreBtn" styleClass="chat-action-btn" onAction="#handleMore">
                <graphic><FontIcon iconLiteral="fas-ellipsis-v" iconSize="15" styleClass="chat-action-icon"/></graphic>
            </Button>
        </HBox>

        <!-- Empty state — shown when no conversation is selected -->
        <VBox fx:id="emptyState" VBox.vgrow="ALWAYS" alignment="CENTER" spacing="20">
            <!-- Blurred color blob + icon overlay -->
            <StackPane alignment="CENTER" prefWidth="140" prefHeight="140" maxWidth="140" maxHeight="140">
                <Region styleClass="chat-empty-blob">
                    <effect><GaussianBlur radius="14"/></effect>
                </Region>
                <FontIcon iconLiteral="fas-comments" iconSize="40" styleClass="chat-empty-icon-fa"/>
            </StackPane>
            <VBox alignment="CENTER" spacing="5">
                <Label text="Select a conversation" styleClass="chat-empty-text"/>
                <Label text="Your messages with tutors will appear here."
                       styleClass="chat-empty-sub" wrapText="true" textAlignment="CENTER" maxWidth="280"/>
                <padding><Insets bottom="28"/></padding>
            </VBox>
        </VBox>

        <!-- Messages scroll area — shown when conversation is selected -->
        <ScrollPane fx:id="messagesScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                    styleClass="chat-messages-scroll" managed="false" visible="false">
            <VBox fx:id="messagesContainer" styleClass="chat-messages-container" spacing="12">
                <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
            </VBox>
        </ScrollPane>

        <!-- Input area — shown when conversation is selected -->
        <HBox fx:id="inputArea" styleClass="chat-input-area" spacing="10"
              alignment="CENTER" managed="false" visible="false">
            <padding><Insets top="12" right="16" bottom="12" left="16"/></padding>
            <TextField fx:id="messageInput" HBox.hgrow="ALWAYS"
                       promptText="Type a message…"
                       styleClass="chat-input"
                       onAction="#handleSend"/>
            <Button fx:id="sendBtn" text="Send" onAction="#handleSend"
                    styleClass="chat-send-btn"/>
        </HBox>

    </VBox>

</HBox>
