<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.ispw.tutora.controller.graphic.StudentProfileGfxController"
      styleClass="profile-root"
      stylesheets="@../css/home.css"
      spacing="0">

    <!-- ============================================================ -->
    <!-- Top bar                                                      -->
    <!-- ============================================================ -->
    <HBox styleClass="profile-topbar" alignment="CENTER_LEFT" spacing="12">
        <Button onAction="#handleClose" styleClass="profile-back-btn">
            <graphic><FontIcon iconLiteral="fas-arrow-left" iconSize="13" styleClass="profile-back-icon"/></graphic>
        </Button>
        <Label text="My Profile" styleClass="profile-topbar-title"/>
    </HBox>

    <!-- ============================================================ -->
    <!-- Scrollable content                                           -->
    <!-- ============================================================ -->
    <ScrollPane fitToWidth="true" styleClass="profile-scroll" VBox.vgrow="ALWAYS">
        <VBox styleClass="profile-content" spacing="24">
            <padding><Insets top="36" right="48" bottom="36" left="48"/></padding>

            <!-- ── Hero card ─────────────────────────────────────── -->
            <HBox styleClass="profile-hero-card" spacing="28" alignment="CENTER_LEFT">
                <padding><Insets top="32" right="36" bottom="32" left="36"/></padding>

                <!-- Avatar con overlay per cambio foto -->
                <StackPane fx:id="heroAvatarPane" styleClass="profile-hero-avatar">
                    <!-- Lettera iniziale (default) -->
                    <Label fx:id="heroAvatarLabel" text="S" styleClass="profile-hero-avatar-letter"/>
                    <!-- Foto profilo (visibile dopo il caricamento) -->
                    <ImageView fx:id="heroAvatarImage"
                               fitWidth="88" fitHeight="88"
                               preserveRatio="false"
                               visible="false" managed="false"/>
                    <!-- Overlay scuro con icona camera — appare sull'hover -->
                    <StackPane fx:id="avatarOverlay" styleClass="profile-avatar-overlay" opacity="0">
                        <VBox spacing="4" alignment="CENTER">
                            <FontIcon iconLiteral="fas-camera" iconSize="18" styleClass="profile-avatar-camera-icon"/>
                            <Label text="Change" styleClass="profile-avatar-change-label"/>
                        </VBox>
                    </StackPane>
                </StackPane>

                <!-- Name block -->
                <VBox spacing="8" HBox.hgrow="ALWAYS">
                    <Label fx:id="heroNameLabel"     text="" styleClass="profile-hero-name"/>
                    <Label fx:id="heroUsernameLabel" text="" styleClass="profile-hero-username"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label fx:id="heroRoleLabel"   text="STUDENT" styleClass="profile-hero-role-badge"/>
                        <Label fx:id="heroStatusLabel" text="Active"  styleClass="profile-hero-status-badge"/>
                    </HBox>
                </VBox>

                <!-- Member-since block (right-aligned) -->
                <VBox spacing="4" alignment="CENTER_RIGHT">
                    <Label text="Member since" styleClass="profile-hero-since-label"/>
                    <Label fx:id="heroMemberSinceLabel" text="" styleClass="profile-hero-since-value"/>
                </VBox>
            </HBox>

            <!-- ── Stats row ─────────────────────────────────────── -->
            <HBox spacing="16">

                <VBox fx:id="budgetCard" styleClass="profile-stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                      spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon-wrap,stat-green">
                            <FontIcon iconLiteral="fas-wallet" iconSize="15" styleClass="stat-icon"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="budgetValueLabel" text="€0.00" styleClass="profile-stat-value"/>
                            <Label text="Available Budget" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox fx:id="lessonsCard" styleClass="profile-stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                      spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon-wrap,stat-blue">
                            <FontIcon iconLiteral="fas-book-open" iconSize="15" styleClass="stat-icon"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="lessonsValueLabel" text="…" styleClass="profile-stat-value"/>
                            <Label text="Lessons Booked" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox fx:id="tutorsCard" styleClass="profile-stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                      spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon-wrap,stat-purple">
                            <FontIcon iconLiteral="fas-user-graduate" iconSize="15" styleClass="stat-icon"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="tutorsValueLabel" text="…" styleClass="profile-stat-value"/>
                            <Label text="Tutors Worked With" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <VBox fx:id="ratingCard" styleClass="profile-stat-card" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                      spacing="8" alignment="CENTER_LEFT">
                    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <StackPane styleClass="stat-icon-wrap,stat-orange">
                            <FontIcon iconLiteral="fas-star" iconSize="15" styleClass="stat-icon"/>
                        </StackPane>
                        <VBox spacing="2">
                            <Label fx:id="ratingValueLabel" text="—" styleClass="profile-stat-value"/>
                            <Label text="Avg. Rating Given" styleClass="stat-label"/>
                        </VBox>
                    </HBox>
                </VBox>

            </HBox>

            <!-- ── Bottom two columns ───────────────────────────── -->
            <HBox spacing="16" alignment="TOP_LEFT">

                <!-- Left column -->
                <VBox spacing="16" HBox.hgrow="ALWAYS">

                    <!-- About card -->
                    <VBox styleClass="profile-section-card" spacing="12">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-user" iconSize="13" styleClass="profile-section-icon"/>
                            <Label text="About Me" styleClass="profile-section-title" HBox.hgrow="ALWAYS"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Button fx:id="editDescBtn" onAction="#handleEditDescription" styleClass="profile-edit-btn">
                                <graphic><FontIcon iconLiteral="fas-pencil-alt" iconSize="11" styleClass="profile-section-icon"/></graphic>
                            </Button>
                        </HBox>
                        <Label fx:id="aboutLabel" text="" styleClass="profile-section-body" wrapText="true"/>
                        <TextArea fx:id="aboutTextArea" styleClass="profile-desc-editor"
                                  wrapText="true" visible="false" managed="false" prefRowCount="4"/>
                        <HBox fx:id="descEditButtons" spacing="8" alignment="CENTER_RIGHT"
                              visible="false" managed="false">
                            <Button onAction="#handleCancelDescription" styleClass="profile-cancel-btn" text="Cancel"/>
                            <Button onAction="#handleSaveDescription"   styleClass="profile-save-btn"   text="Save"/>
                        </HBox>
                    </VBox>

                    <!-- Interests card -->
                    <VBox styleClass="profile-section-card" spacing="12">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-heart" iconSize="13" styleClass="profile-section-icon"/>
                            <Label text="Learning Interests" styleClass="profile-section-title"/>
                        </HBox>
                        <FlowPane fx:id="interestsPills" hgap="8" vgap="6" alignment="CENTER_LEFT"/>
                        <Label fx:id="interestsEmptyLabel" text="No interests added yet."
                               styleClass="profile-section-empty" managed="false" visible="false"/>
                    </VBox>

                    <!-- Preferred tutors card -->
                    <VBox styleClass="profile-section-card" spacing="12">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-heart" iconSize="13" styleClass="profile-section-icon"/>
                            <Label text="Preferred Tutors" styleClass="profile-section-title"/>
                        </HBox>
                        <VBox fx:id="preferredTutorsBox" spacing="6"/>
                        <Label fx:id="preferredTutorsEmptyLabel" text="No preferred tutors yet."
                               styleClass="profile-section-empty" managed="false" visible="false"/>
                    </VBox>

                </VBox>

                <!-- Right column -->
                <VBox spacing="16" prefWidth="300" minWidth="280">

                    <!-- Contact card -->
                    <VBox styleClass="profile-section-card" spacing="14">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-address-card" iconSize="13" styleClass="profile-section-icon"/>
                            <Label text="Contact Info" styleClass="profile-section-title"/>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-envelope" iconSize="12" styleClass="profile-field-icon"/>
                            <VBox spacing="2">
                                <Label text="Email" styleClass="profile-field-label"/>
                                <Label fx:id="emailLabel" text="" styleClass="profile-field-value"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-calendar-alt" iconSize="12" styleClass="profile-field-icon"/>
                            <VBox spacing="2">
                                <Label text="Joined" styleClass="profile-field-label"/>
                                <Label fx:id="joinedLabel" text="" styleClass="profile-field-value"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-shield-alt" iconSize="12" styleClass="profile-field-icon"/>
                            <VBox spacing="2">
                                <Label text="Account" styleClass="profile-field-label"/>
                                <Label fx:id="accountStatusLabel" text="" styleClass="profile-field-value"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-wallet" iconSize="12" styleClass="profile-field-icon"/>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Budget" styleClass="profile-field-label"/>
                                <Label fx:id="budgetDetailLabel" text="" styleClass="profile-field-value"/>
                                <HBox fx:id="budgetEditBox" spacing="6" alignment="CENTER_LEFT"
                                      visible="false" managed="false">
                                    <TextField fx:id="budgetField" styleClass="profile-budget-field"
                                               promptText="e.g. 150.00" prefWidth="95"/>
                                    <Button onAction="#handleCancelBudget"
                                            style="-fx-background-color:#DC2626; -fx-background-insets:0; -fx-background-radius:8; -fx-border-width:0; -fx-padding:6; -fx-cursor:hand; -fx-min-width:28; -fx-min-height:28; -fx-max-width:28; -fx-max-height:28;">
                                        <graphic><FontIcon iconLiteral="fas-times" iconSize="12" styleClass="budget-cancel-icon"/></graphic>
                                    </Button>
                                    <Button onAction="#handleSaveBudget"
                                            style="-fx-background-color:#2A5C45; -fx-background-insets:0; -fx-background-radius:8; -fx-border-width:0; -fx-padding:6; -fx-cursor:hand; -fx-min-width:28; -fx-min-height:28; -fx-max-width:28; -fx-max-height:28;">
                                        <graphic><FontIcon iconLiteral="fas-check" iconSize="12" styleClass="budget-confirm-icon"/></graphic>
                                    </Button>
                                </HBox>
                            </VBox>
                            <Button fx:id="editBudgetBtn" onAction="#handleEditBudget" styleClass="profile-edit-btn">
                                <graphic><FontIcon iconLiteral="fas-pencil-alt" iconSize="11" styleClass="profile-section-icon"/></graphic>
                            </Button>
                        </HBox>
                    </VBox>

                    <!-- Preferences card -->
                    <VBox styleClass="profile-section-card" spacing="14">
                        <padding><Insets top="22" right="24" bottom="22" left="24"/></padding>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <FontIcon iconLiteral="fas-sliders-h" iconSize="13" styleClass="profile-section-icon"/>
                            <Label text="Preferences" styleClass="profile-section-title"/>
                        </HBox>
                        <Label text="Notifications" styleClass="profile-field-label"/>
                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label styleClass="pref-badge" text="Email alerts"/>
                            <Label styleClass="pref-badge" text="In-app"/>
                        </HBox>
                        <Label text="Language" styleClass="profile-field-label"/>
                        <Label text="English" styleClass="profile-field-value"/>
                    </VBox>

                </VBox>
            </HBox>

        </VBox>
    </ScrollPane>

</VBox>
