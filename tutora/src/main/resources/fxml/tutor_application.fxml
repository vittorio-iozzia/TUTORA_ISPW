<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="it.ispw.tutora.controller.graphic.TutorApplicationGfxController"
      fx:id="dialogRoot"
      stylesheets="@../css/home.css"
      styleClass="app-dialog-root app-dialog-form"
      spacing="0" minWidth="560" prefWidth="720" prefHeight="700">

    <!-- ── Header ── -->
    <HBox styleClass="app-dialog-header" alignment="CENTER_LEFT" spacing="16">
        <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
        <StackPane fx:id="headerIconWrap" styleClass="app-header-icon-wrap">
            <ImageView fx:id="headerIconView" fitWidth="22" fitHeight="22" preserveRatio="true" smooth="true"/>
        </StackPane>
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label fx:id="titleLabel" text="Apply as Tutor" styleClass="app-header-title"/>
            <Label fx:id="subtitleLabel" text="Fill out the form below to apply as a tutor."
                   styleClass="app-header-subtitle" wrapText="true"/>
        </VBox>
        <Button onAction="#handleBack" styleClass="app-dialog-close-btn" text="✕"/>
    </HBox>

    <!-- ── Applying For banner ── -->
    <HBox fx:id="applyingForBanner" styleClass="app-applying-banner" alignment="CENTER_LEFT" spacing="10">
        <VBox.margin><Insets top="12" right="20" bottom="12" left="20"/></VBox.margin>
        <padding><Insets top="10" right="14" bottom="10" left="14"/></padding>
        <StackPane fx:id="bannerIconWrap" styleClass="app-applying-icon-wrap">
            <ImageView fx:id="bannerIconView" fitWidth="13" fitHeight="13" preserveRatio="true" smooth="true"/>
        </StackPane>
        <Label fx:id="applyingForLabel" text="Applying for: — Category" styleClass="app-applying-label"/>
    </HBox>

    <!-- ── Form (scrollable) ── -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="app-scroll">
        <VBox fx:id="formContainer" spacing="14">
            <padding><Insets top="20" right="20" bottom="12" left="20"/></padding>
        </VBox>
    </ScrollPane>

    <!-- ── Success pane (initially hidden) ── -->
    <VBox fx:id="successPane" visible="false" managed="false"
          alignment="CENTER" spacing="18" VBox.vgrow="ALWAYS">
        <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

        <StackPane fx:id="successIconWrap" styleClass="app-success-icon-wrap" maxWidth="72" maxHeight="72">
            <ImageView fx:id="successIconView" fitWidth="34" fitHeight="34" preserveRatio="true" smooth="true"/>
        </StackPane>

        <Label text="Application submitted!" styleClass="app-success-title"/>
        <Label text="The TUTORA team will review your application and get back to you within 2–3 business days."
               styleClass="app-success-desc" wrapText="true" textAlignment="CENTER" maxWidth="380"/>

        <VBox styleClass="app-success-steps" spacing="10" maxWidth="380">
            <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
            <Label text="📋  Application review (2–3 days)"       styleClass="app-success-step"/>
            <Label text="🎥  Video interview (if selected)"        styleClass="app-success-step"/>
            <Label text="✅  Profile setup and onboarding"         styleClass="app-success-step"/>
            <Label text="🚀  Start accepting students!"            styleClass="app-success-step"/>
        </VBox>

        <Button fx:id="closeBtn" text="Got it, thanks!"
                onAction="#handleClose"
                styleClass="app-submit-btn"
                maxWidth="320" prefWidth="320"/>
    </VBox>

    <!-- ── Footer ── -->
    <VBox fx:id="footer" styleClass="app-dialog-footer" spacing="10">
        <padding><Insets top="14" right="20" bottom="14" left="20"/></padding>
        <Label fx:id="errorLabel" text="" styleClass="app-error-label"
               visible="false" managed="false" wrapText="true"/>
        <HBox styleClass="app-tos-box" alignment="TOP_LEFT" spacing="10">
            <CheckBox fx:id="agreeCheckBox" styleClass="app-tos-check"/>
            <Label fx:id="agreeLabel" styleClass="app-tos-label" wrapText="true"
                   HBox.hgrow="ALWAYS"/>
        </HBox>
        <Button fx:id="submitBtn" text="Submit application"
                onAction="#handleSubmit"
                styleClass="app-submit-btn"
                maxWidth="Infinity" disable="true"/>
    </VBox>

</VBox>
