<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="it.ispw.tutora.controller.graphic.ApplyToBecomeATutorGfxController"
            style="-fx-background-color: #f5f5f5;">

    <!-- ============================================================ -->
    <!-- Header                                                        -->
    <!-- ============================================================ -->
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color: #1a237e; -fx-padding: 12 20 12 20;">

            <Button text="&lt; Back"
                    onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white;
                           -fx-font-size: 12; -fx-cursor: hand;"/>

            <Label text="Apply to Become a Tutor"
                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
        </HBox>
    </top>

    <!-- ============================================================ -->
    <!-- Contenuto centrale                                            -->
    <!-- ============================================================ -->
    <center>
        <StackPane>

            <!-- ============================================================ -->
            <!-- Fase 1: selezione categoria                           -->
            <!-- ============================================================ -->
            <VBox fx:id="categorySection" spacing="12"
                  style="-fx-padding: 24;">

                <Label text="Select a Category"
                       style="-fx-font-size: 15; -fx-font-weight: bold;"/>

                <Label text="Choose the subject area you want to teach as a tutor."
                       style="-fx-font-size: 12; -fx-text-fill: #757575;" wrapText="true"/>

                <!-- Lista categorie -->
                <ListView fx:id="categoryListView"
                          prefHeight="160"
                          style="-fx-border-color: #bdbdbd;"/>

                <!-- Descrizione categoria selezionata -->
                <Label fx:id="categoryDescriptionLabel"
                       wrapText="true"
                       style="-fx-font-size: 12; -fx-text-fill: #555555;"
                       minHeight="32"/>

                <!-- Errore fase 1 -->
                <Label fx:id="categoryErrorLabel"
                       style="-fx-text-fill: #c62828; -fx-font-size: 12;"
                       visible="false" wrapText="true"/>

                <!-- Pulsante avanti -->
                <Button fx:id="nextButton"
                        text="Next &gt;"
                        onAction="#handleNext"
                        style="-fx-background-color: #1a237e; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-cursor: hand;"
                        maxWidth="Infinity"/>

            </VBox>

            <!-- ============================================================ -->
            <!-- Fase 2: form requisiti                                -->
            <!-- ============================================================ -->
            <VBox fx:id="formSection" spacing="12"
                  visible="false" managed="false"
                  style="-fx-padding: 24;">

                <!-- Categoria selezionata -->
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Category:"
                           style="-fx-font-size: 13; -fx-font-weight: bold;"/>
                    <Label fx:id="selectedCategoryLabel"
                           style="-fx-font-size: 13; -fx-text-fill: #1a237e;"/>
                </HBox>

                <Label text="Fill in all required fields (* = required)."
                       style="-fx-font-size: 12; -fx-text-fill: #757575;"/>

                <Separator/>

                <!-- Form dinamico dentro ScrollPane -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <VBox fx:id="formContent" spacing="12">
                        <padding>
                            <Insets top="4" right="4" bottom="4" left="4"/>
                        </padding>
                    </VBox>
                </ScrollPane>

                <Separator/>

                <!-- Messaggio errore/successo -->
                <Label fx:id="messageLabel"
                       wrapText="true"
                       style="-fx-font-size: 12;"
                       visible="false"/>

                <!-- Pulsante submit -->
                <Button fx:id="submitButton"
                        text="Submit Application"
                        onAction="#handleSubmit"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-cursor: hand;"
                        maxWidth="Infinity"/>

            </VBox>

        </StackPane>
    </center>

</BorderPane>
